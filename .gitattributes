* text=auto eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore

# Force GitHub Linguist to detect CSS and JS in public
public/css/*.css linguist-vendored=false
public/css/*.css linguist-detectable=true
public/js/*.js linguist-vendored=false
public/js/*.js linguist-detectable=true

